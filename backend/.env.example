# Server
PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/legacyguard

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_HEIR_SECRET=different-long-random-string-for-heirs

# Bitcoin Node
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_AUTH=user:password
BITCOIN_NETWORK=testnet

# LND
LND_HOST=localhost:10009
LND_MACAROON_PATH=~/.lnd/data/chain/bitcoin/testnet/admin.macaroon
LND_TLS_CERT_PATH=~/.lnd/tls.cert

# AWS (HSM)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
HSM_CLUSTER_ID=

# Notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_USERNAME=
SENDGRID_API_KEY=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# KYC Provider
SMILE_IDENTITY_API_KEY=
SMILE_IDENTITY_PARTNER_ID=

# Heir Portal
HEIR_PORTAL_URL=https://claim.legacyguard.app
